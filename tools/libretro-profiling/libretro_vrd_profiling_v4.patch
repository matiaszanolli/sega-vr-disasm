+  {
+    extern int vrd_profile_pc_enabled;
+    extern void vrd_profile_pc_sample(int, unsigned int, int);
+    if (vrd_profile_pc_enabled) {
+      /* VRD: chunked execution so we can sample the SH2 PC. Requires the
+         interpreter (DRC is forced off when VRD_PROFILE_PC is set). */
+      int cpu = sh2->is_slave ? 2 : 1;
+      unsigned int remaining = cycles, total = 0;
+      while (remaining > 0) {
+        unsigned int chunk = remaining > 32 ? 32 : remaining;
+        int d = sh2_execute(sh2, chunk);
+        if (d <= 0) break;
