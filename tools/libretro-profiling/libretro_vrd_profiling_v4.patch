+      if (pc_enabled_str && atoi(pc_enabled_str) > 0) {
+         vrd_profile_pc_enabled = 1;
+         if (pc_profile_path) {
+            vrd_profile_pc_log = fopen(pc_profile_path, "w");
+            if (vrd_profile_pc_log)
