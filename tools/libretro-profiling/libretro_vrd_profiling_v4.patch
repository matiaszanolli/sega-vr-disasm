diff --git a/platform/libretro/libretro.c b/platform/libretro/libretro.c
index a6f2bf6..d93e9a4 100644
--- a/platform/libretro/libretro.c
+++ b/platform/libretro/libretro.c
@@ -94,6 +94,214 @@ static retro_input_state_t input_state_cb;
 static retro_environment_t environ_cb;
 static retro_audio_sample_batch_t audio_batch_cb;
 
+/* ======================================================================== */
+/* VRD Profiling instrumentation                                            */
+/* ======================================================================== */
+static FILE *vrd_profile_log = NULL;
+static int vrd_profile_enabled = 0;
+static int vrd_profile_frame = 0;
+static int vrd_profile_max_frames = 2400;
+
+/* PC-level profiling */
+int vrd_profile_pc_enabled = 0;
+static FILE *vrd_profile_pc_log = NULL;
+
+/* PC sample histogram (hash table per CPU: 0=68K, 1=Master SH2, 2=Slave SH2) */
+#define VRD_PC_HASH_SIZE 65536
+#define VRD_PC_HASH_MASK (VRD_PC_HASH_SIZE - 1)
+typedef struct {
+    unsigned int pc;
+    unsigned int total_cycles;
+    unsigned int count;
+} vrd_pc_entry_t;
+static vrd_pc_entry_t vrd_pc_table[3][VRD_PC_HASH_SIZE];
+static int vrd_pc_used[3] = {0, 0, 0};
+
+/* VRD: exact idle/useful cycle accounting (every sample counted — immune to the
+   top-N histogram truncation). Per CPU: 0=68K, 1=Master SH2, 2=Slave SH2. */
+static unsigned int       vrd_frame_idle[3]   = {0,0,0};  /* reset each frame */
+static unsigned int       vrd_frame_useful[3] = {0,0,0};
+static unsigned long long vrd_cum_idle[3]     = {0,0,0};  /* over counted frames */
+static unsigned long long vrd_cum_useful[3]   = {0,0,0};
+
+/* VRD: 3D-phase gating (count only frames where the Slave is rendering 3D) */
+static int          vrd_gate_3d = 0;            /* VRD_GATE_3D=1 to enable */
+static unsigned int vrd_gate_thresh = 150000;   /* ssh2 cycles/frame => 3D-active */
+static int          vrd_3d_active = 0;          /* from previous frame's ssh2 work */
+static int          vrd_active_frames = 0;
+
+/* Classify a sampled PC as idle (poll / V-blank-wait / delay loop) vs useful work.
+   68K idle = BIOS main-loop poll in WRAM ($FF0000+).
+   SH2 idle = Master dispatch poll / Slave command poll + delay loop / boot idle. */
+static int vrd_is_idle_pc(int cpu_id, unsigned int pc)
+{
+    if (cpu_id == 0) {                                  /* 68K non-compute (idle + SH2 sync waits) */
+        if (pc >= 0xFF0000) return 1;                  /* BIOS main-loop V-blank poll */
+        if (pc >= 0x88E35A && pc <= 0x88E362) return 1; /* sh2_send_cmd COMM0_HI wait (blocked on SH2) */
+        if (pc >= 0x88E316 && pc <= 0x88E31E) return 1; /* sh2_send_cmd_wait COMM0_HI wait */
+        return 0;
+    }
+    if (cpu_id == 1) {                                 /* Master SH2 (empirical poll PCs) */
+        if (pc >= 0x06004230 && pc < 0x06004260) return 1;  /* dispatch/idle poll $0600424E */
+        if (pc >= 0x06000440 && pc < 0x06000492) return 1;  /* secondary poll */
+    } else {                                           /* Slave SH2 */
+        if (pc >= 0x06000580 && pc < 0x06000660) return 1;  /* cmd poll + delay loop */
+        if (pc >= 0x020003C0 && pc < 0x020003E0) return 1;  /* boot idle $0203CC */
+    }
+    return 0;
+}
+
+/* ===================== VRD Tier 2: runtime inspection ===================== */
+extern struct Pico32xMem *Pico32xMem;
+extern u32 REGPARM(2) p32x_sh2_read8(u32 a, SH2 *sh2);
+extern u32 REGPARM(2) p32x_sh2_read16(u32 a, SH2 *sh2);
+
+/* Generic read routed to the right bus: 68K (ROM/WRAM) vs SH2 (FB/SDRAM/etc). */
+static unsigned vrd_r16(unsigned addr) {
+    extern M68K_CONTEXT PicoCpuFM68k;
+    if (addr < 0x400000 || (addr >= 0xFF0000 && addr <= 0xFFFFFF))
+        return PicoCpuFM68k.read_word(addr) & 0xFFFF;
+    return p32x_sh2_read16(addr, &msh2) & 0xFFFF;
+}
+static unsigned vrd_r8(unsigned addr) {
+    extern M68K_CONTEXT PicoCpuFM68k;
+    if (addr < 0x400000 || (addr >= 0xFF0000 && addr <= 0xFFFFFF))
+        return PicoCpuFM68k.read_byte(addr) & 0xFF;
+    return p32x_sh2_read8(addr, &msh2) & 0xFF;
+}
+
+/* FNV-1a hash of the currently-displayed framebuffer (decisive "did the image
+   change between frames?" signal — no host video needed). */
+static unsigned vrd_fb_crc(void) {
+    unsigned short *fb; unsigned h = 2166136261u; int i;
+    if (!Pico32xMem) return 0;
+    fb = Pico32xMem->dram[(Pico32x.vdp_regs[0x0a/2] & P32XV_FS) ^ 1];
+    for (i = 0; i < 0x20000/2; i++) { h ^= fb[i]; h *= 16777619u; }
+    return h;
+}
+
+#define VRD_MAX_WATCH 32
+static unsigned vrd_watch_addr[VRD_MAX_WATCH], vrd_watch_size[VRD_MAX_WATCH];
+static int   vrd_watch_n = 0;
+static FILE *vrd_watch_log = NULL;
+static long  vrd_dump_frame = -1;
+static char  vrd_dump_spec[256] = "";
+static char  vrd_dump_file[256] = "";
+static int   vrd_fb_crc_on = 0;
+static unsigned vrd_scene_addr = 0xC87E;   /* 68K game-state word ($FFC87E) */
+
+static void vrd_parse_watch(const char *s) {
+    while (s && *s && vrd_watch_n < VRD_MAX_WATCH) {
+        unsigned a = 0, sz = 2;
+        if (sscanf(s, "%x:%u", &a, &sz) >= 1) {
+            vrd_watch_addr[vrd_watch_n] = a;
+            vrd_watch_size[vrd_watch_n] = sz ? sz : 2;
+            vrd_watch_n++;
+        }
+        s = strchr(s, ','); if (s) s++;
+    }
+}
+static unsigned vrd_readN(unsigned a, unsigned sz) {
+    if (sz <= 1) return vrd_r8(a);
+    if (sz == 2) return vrd_r16(a);
+    return (vrd_r16(a) << 16) | vrd_r16(a + 2);   /* 4-byte */
+}
+static void vrd_dump_regions(void) {
+    const char *path = vrd_dump_file[0] ? vrd_dump_file : "vrd_dump.txt";
+    FILE *f = fopen(path, "w");
+    const char *s = vrd_dump_spec;
+    if (!f) return;
+    while (s && *s) {
+        unsigned a = 0, len = 64, i;
+        if (sscanf(s, "%x:%u", &a, &len) >= 1) {
+            fprintf(f, "# DUMP %08X..%08X\n", a, a + len);
+            for (i = 0; i < len; i += 16) {
+                unsigned j; fprintf(f, "%08X:", a + i);
+                for (j = 0; j < 16 && i + j < len; j += 2)
+                    fprintf(f, " %04X", vrd_r16(a + i + j));
+                fprintf(f, "\n");
+            }
+        }
+        s = strchr(s, ','); if (s) s++;
+    }
+    fclose(f);
+}
+
+/* WRAM caller tracking: when 68K PC is in WRAM ($FF0000+), record
+   the last non-WRAM PC as the "caller" to identify what triggers polling */
+static vrd_pc_entry_t vrd_wram_caller_table[VRD_PC_HASH_SIZE];
+static int vrd_wram_caller_used = 0;
+static unsigned int vrd_last_non_wram_pc = 0;
+
+static void vrd_wram_caller_record(unsigned int caller_pc, int cycles)
+{
+    unsigned int hash, i;
+    hash = (caller_pc >> 1) & VRD_PC_HASH_MASK;
+    for (i = 0; i < VRD_PC_HASH_SIZE; i++) {
+        unsigned int idx = (hash + i) & VRD_PC_HASH_MASK;
+        if (vrd_wram_caller_table[idx].pc == caller_pc) {
+            vrd_wram_caller_table[idx].total_cycles += cycles;
+            vrd_wram_caller_table[idx].count++;
+            return;
+        }
+        if (vrd_wram_caller_table[idx].count == 0) {
+            vrd_wram_caller_table[idx].pc = caller_pc;
+            vrd_wram_caller_table[idx].total_cycles = cycles;
+            vrd_wram_caller_table[idx].count = 1;
+            vrd_wram_caller_used++;
+            return;
+        }
+    }
+}
+
+/* SH2 work cycle counters from 32x.c */
+extern unsigned int vrd_msh2_work_cycles;
+extern unsigned int vrd_ssh2_work_cycles;
+
+/* PC sample collection with open-addressing hash table */
+void vrd_profile_pc_sample(int cpu_id, unsigned int pc, int cycles)
+{
+    unsigned int hash, i;
+    vrd_pc_entry_t *t;
+
+    if (cpu_id < 0 || cpu_id > 2) return;
+
+    /* VRD: 3D-phase gate — ignore samples outside 3D-active frames */
+    if (vrd_gate_3d && !vrd_3d_active) return;
+    /* VRD: exact idle/useful accounting (independent of histogram truncation) */
+    if (vrd_is_idle_pc(cpu_id, pc)) vrd_frame_idle[cpu_id]   += (unsigned)cycles;
+    else                            vrd_frame_useful[cpu_id] += (unsigned)cycles;
+
+    /* WRAM caller tracking (68K only) */
+    if (cpu_id == 0) {
+        if (pc >= 0xFF0000) {
+            if (vrd_last_non_wram_pc != 0)
+                vrd_wram_caller_record(vrd_last_non_wram_pc, cycles);
+        } else {
+            vrd_last_non_wram_pc = pc;
+        }
+    }
+
+    t = vrd_pc_table[cpu_id];
+    hash = (pc >> 1) & VRD_PC_HASH_MASK;
+
+    for (i = 0; i < VRD_PC_HASH_SIZE; i++) {
+        unsigned int idx = (hash + i) & VRD_PC_HASH_MASK;
+        if (t[idx].pc == pc) {
+            t[idx].total_cycles += cycles;
+            t[idx].count++;
+            return;
+        }
+        if (t[idx].count == 0) {
+            t[idx].pc = pc;
+            t[idx].total_cycles = cycles;
+            t[idx].count = 1;
+            vrd_pc_used[cpu_id]++;
+            return;
+        }
+    }
+}
+
 #define VOUT_MAX_WIDTH 320
 #define VOUT_MAX_HEIGHT 240
 
@@ -1960,6 +2168,8 @@ static void update_variables(bool first_run)
       else
          PicoIn.opt &= ~POPT_EN_DRC;
    }
+   if (getenv("VRD_PROFILE_PC"))   /* VRD: SH2 interpreter required for PC sampling */
+      PicoIn.opt &= ~POPT_EN_DRC;
 #endif
 #ifdef _3DS
    if(!ctr_svchack_successful)
@@ -2406,8 +2616,209 @@ void retro_run(void)
       update_audio_latency = false;
    }
 
+   /* VRD Profiling: Initialize on first frame */
+   if (vrd_profile_frame == 0) {
+      const char *profile_path = getenv("VRD_PROFILE_LOG");
+      const char *max_frames_str = getenv("VRD_PROFILE_FRAMES");
