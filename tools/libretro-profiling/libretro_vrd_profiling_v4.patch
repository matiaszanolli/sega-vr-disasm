+      { const char *t = getenv("VRD_GATE_THRESH"); if (t && atoi(t) > 0) vrd_gate_thresh = (unsigned)atoi(t); }
+      /* Tier 2: runtime inspection */
+      { const char *w  = getenv("VRD_WATCH");      if (w) vrd_parse_watch(w); }
+      { const char *wl = getenv("VRD_WATCH_LOG");  if (wl) vrd_watch_log = fopen(wl, "w"); }
+      { const char *df = getenv("VRD_DUMP_FRAME"); if (df) vrd_dump_frame = atol(df); }
+      { const char *ds = getenv("VRD_DUMP");       if (ds) strncpy(vrd_dump_spec, ds, sizeof(vrd_dump_spec)-1); }
+      { const char *dl = getenv("VRD_DUMP_FILE");  if (dl) strncpy(vrd_dump_file, dl, sizeof(vrd_dump_file)-1); }
+      { const char *fc = getenv("VRD_FB_CRC");     if (fc && atoi(fc) > 0) vrd_fb_crc_on = 1; }
+      { const char *sa = getenv("VRD_SCENE_ADDR"); vrd_scene_addr = sa ? (unsigned)strtoul(sa,0,16) : 0xFFC87E; }
+      if (vrd_watch_log) {
+         int wi; fprintf(vrd_watch_log, "frame");
+         for (wi = 0; wi < vrd_watch_n; wi++) fprintf(vrd_watch_log, ",0x%X", vrd_watch_addr[wi]);
+         fprintf(vrd_watch_log, "\n");
+      }
+   }
+
+   /* VRD Profiling: Pre-frame state capture */
+   int vrd_is_32x = (PicoIn.AHW & PAHW_32X) ? 1 : 0;
+   unsigned int vrd_m68k_before = 0;
+   if ((vrd_profile_enabled || vrd_profile_pc_enabled) &&
+       vrd_profile_frame < vrd_profile_max_frames && vrd_is_32x) {
+      vrd_msh2_work_cycles = 0;
+      vrd_ssh2_work_cycles = 0;
+      vrd_frame_idle[0] = vrd_frame_idle[1] = vrd_frame_idle[2] = 0;
+      vrd_frame_useful[0] = vrd_frame_useful[1] = vrd_frame_useful[2] = 0;
+      vrd_m68k_before = SekCyclesDone();
+   }
+
    PicoFrame();
 
+   /* VRD Tier 2: per-frame runtime inspection (independent of profile logs) */
+   if (PicoIn.AHW & PAHW_32X) {
+      if (vrd_watch_log) {
+         int wi; fprintf(vrd_watch_log, "%d", vrd_profile_frame);
+         for (wi = 0; wi < vrd_watch_n; wi++)
+            fprintf(vrd_watch_log, ",0x%X", vrd_readN(vrd_watch_addr[wi], vrd_watch_size[wi]));
+         fprintf(vrd_watch_log, "\n");
+      }
+      if ((long)vrd_profile_frame == vrd_dump_frame) vrd_dump_regions();
+   }
+
+   /* VRD Profiling: Post-frame logging */
+   if ((vrd_profile_enabled || vrd_profile_pc_enabled) &&
+       vrd_profile_frame < vrd_profile_max_frames && vrd_is_32x) {
+      unsigned int vrd_m68k_cycles = SekCyclesDone() - vrd_m68k_before;
+      int vrd_active = (!vrd_gate_3d) || vrd_3d_active;
+
+      if (vrd_active) {
+         int c;
+         vrd_active_frames++;
+         for (c = 0; c < 3; c++) {
+            vrd_cum_useful[c] += vrd_frame_useful[c];
+            vrd_cum_idle[c]   += vrd_frame_idle[c];
+         }
+      }
+
+      if (vrd_profile_enabled && vrd_profile_log) {
+         unsigned vrd_fbcrc = vrd_fb_crc_on ? vrd_fb_crc() : 0;
+         unsigned vrd_scene = vrd_r16(0xFF0004);          /* scene-handler low word */
+         unsigned vrd_state = vrd_r16(vrd_scene_addr);    /* game state ($FFC87E) */
+         fprintf(vrd_profile_log, "%d,%u,%u,%u,%u,%u,%u,%d,0x%08X,0x%04X,0x%04X,%d\n",
+                 vrd_profile_frame, vrd_m68k_cycles,
+                 vrd_msh2_work_cycles, vrd_ssh2_work_cycles,
+                 vrd_frame_useful[0], vrd_frame_useful[1], vrd_frame_useful[2],
+                 vrd_active, vrd_fbcrc, vrd_scene, vrd_state, vrd_is_32x);
+      }
+
+      /* gate the NEXT frame on this frame's Slave 3D workload */
+      vrd_3d_active = (vrd_ssh2_work_cycles > vrd_gate_thresh);
+
+      if (vrd_profile_frame == vrd_profile_max_frames - 1) {
+         if (vrd_profile_enabled && vrd_profile_log) {
+            fclose(vrd_profile_log); vrd_profile_log = NULL;
+         }
+
+         /* Export PC histogram */
+         if (vrd_profile_pc_enabled && vrd_profile_pc_log) {
+            const char *cpu_names[] = {"68K", "Master", "Slave"};
+            int cpu, i, j;
+
+            for (cpu = 0; cpu < 3; cpu++) {
+               unsigned int total = 0;
+               static vrd_pc_entry_t sorted[VRD_PC_HASH_SIZE];
+               int n = 0;
+               for (i = 0; i < VRD_PC_HASH_SIZE; i++) {
